{
  "expo": {
    "name": "city-discover-app",
    "slug": "city-discover-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "citydiscoverapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.raumain.citydiscover"
    },
    "android": {
      "package": "com.raumain.citydiscover",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "@sentry/react-native/expo",
        {
          "organization": "your-sentry-org",
          "project": "city-discover-app"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow City Discover to access your location while walking to track discovered streets.",
          "locationWhenInUsePermission": "Allow City Discover to access your location while walking to track discovered streets.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true,
          "foregroundService": {
            "notificationTitle": "City Discover is tracking your walk",
            "notificationBody": "Tracking active street discovery in the background."
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
